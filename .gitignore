# Build artifacts
/target/
*.img

# Hermit loader binary (downloaded, not committed)
hermit-loader-x86_64
hermit-loader

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.idea/
.vscode/
*.code-workspace

# LibreOffice lock files
.~lock.*

# Claude Code (keep agents, ignore local settings)
.claude/settings.local.json
.claude/projects/
.claude/memory/

# Admin private key — NEVER commit this
admin_priv.pem

# TLS certificates — never commit real certs/keys
data/tls/*.pem
data/tls/*.key
data/tls/*.crt

# VirtioFS temp
/tmp/
